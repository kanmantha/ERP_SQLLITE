@model ERP.Web.Models.StockMovement
@{ ViewData["Title"] = "Record Stock Movement"; }
<h2>Record Stock Movement</h2>
<div class="row">
    <div class="col-md-4">
        <form asp-action="AddMovement">
            <div class="form-group">
                <label asp-for="ProductId"></label>
                <select asp-for="ProductId" class="form-control" asp-items="ViewBag.ProductId"></select>
            </div>
            <div class="form-group">
                <label asp-for="Type"></label>
                <select asp-for="Type" class="form-control">
                    <option value="In">Stock In (+)</option>
                    <option value="Out">Stock Out (-)</option>
                </select>
            </div>
            <div class="form-group">
                <label asp-for="Quantity"></label>
                <input asp-for="Quantity" class="form-control" type="number" min="1" />
            </div>
            <div class="form-group">
                <label asp-for="Reason"></label>
                <input asp-for="Reason" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Date">Date</label>
                <input name="movementDateString" class="form-control" type="date" value="@Model.Date.ToString("yyyy-MM-dd")" />
            </div>
            <button type="submit" class="btn btn-primary">Record</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </form>
    </div>
</div>
