@model IEnumerable<ERP.Web.Models.Product>
@{ ViewData["Title"] = "Inventory Levels"; }

<h2>Inventory Levels</h2>
<div class="row">
    <div class="col-md-12">
        <table class="table">
            <thead>
                <tr>
                    <th>Product Name</th>
                    <th>Description</th>
                    <th>Price</th>
                    <th>Current Stock</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var status = item.Stock <= 5 ? "text-danger" : "text-success";
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Description</td>
                        <td>@item.Price.ToString("C")</td>
                        <td class="@(item.Stock <= 5 ? "text-danger fw-bold" : "")">@item.Stock</td>
                        <td><span class="badge @(item.Stock > 5 ? "bg-success" : "bg-danger")">@(item.Stock <= 5 ? "Low Stock" : "In Stock")</span></td>
                    </tr>
                }
            </tbody>
        </table>
        <a asp-action="AddMovement" class="btn btn-primary">Record Stock Movement</a> |
        <a asp-action="Movements" class="btn btn-secondary">View History</a>
    </div>
</div>
