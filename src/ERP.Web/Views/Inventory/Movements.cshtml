@model IEnumerable<ERP.Web.Models.StockMovement>
@{ ViewData["Title"] = "Stock History"; }
<h2>Stock History</h2>
<table class="table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Product</th>
            <th>Type</th>
            <th>Qty</th>
            <th>Reason</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Date.ToShortDateString()</td>
                <td>@item.Product.Name</td>
                <td>
                    <span class="badge @(item.Type == "In" ? "bg-success" : "bg-danger")">@item.Type</span>
                </td>
                <td>@item.Quantity</td>
                <td>@item.Reason</td>
            </tr>
        }
    </tbody>
</table>
<a asp-action="Index" class="btn btn-secondary">Back to Inventory</a>
