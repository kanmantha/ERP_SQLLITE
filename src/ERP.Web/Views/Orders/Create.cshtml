@model ERP.Web.Models.Order
@{
    ViewData["Title"] = "Create Order";
}

<h2>Create New Order</h2>

<!-- Display validation errors prominently -->
<div asp-validation-summary="All" class="text-danger" style="color: red; font-weight: bold; margin-bottom: 1rem;"></div>

<!-- Display custom error messages from controller -->
@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        <strong>Error:</strong> @Html.Raw(ViewBag.Error)
    </div>
}

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group">
                <label asp-for="CustomerId">Customer</label>
                <select asp-for="CustomerId" class="form-control" asp-items="ViewBag.CustomerId">
                    <option value="">-- Select Customer --</option>
                </select>
                <span asp-validation-for="CustomerId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OrderDate">Order Date</label>
                <!-- Name attribute explicitly binds to orderDateString in controller -->
                <input name="orderDateString" class="form-control" type="date" value="@Model.OrderDate.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="OrderDate" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Create</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </form>
    </div>
</div>
